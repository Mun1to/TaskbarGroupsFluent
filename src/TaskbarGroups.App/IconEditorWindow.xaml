<ui:FluentWindow x:Class="TaskbarGroups.App.IconEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Ajustar icono"
        Height="540" Width="420"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Ajustar icono" Padding="12,6" />

        <StackPanel Grid.Row="1" Margin="24,8,24,0" HorizontalAlignment="Center">
            <TextBlock Text="Arrastra para mover · rueda o barra para acercar"
                       FontSize="12" Margin="0,0,0,12" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <Border Width="320" Height="320" CornerRadius="12"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <Canvas x:Name="CropCanvas" Width="320" Height="320" ClipToBounds="True"
                        Background="Transparent"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseMove="Canvas_MouseMove"
                        MouseWheel="Canvas_MouseWheel">
                    <Image x:Name="EditImage" Stretch="Fill"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Canvas>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                <TextBlock Text="−" FontSize="18" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Slider x:Name="ZoomSlider" Width="220" Margin="10,0"
                        Minimum="1" Maximum="4" Value="1"
                        VerticalAlignment="Center" ValueChanged="ZoomSlider_ValueChanged" />
                <TextBlock Text="+" FontSize="18" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Padding="24,12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancelar" Margin="0,0,8,0" Click="Cancel_Click" />
                <ui:Button Content="Aplicar" Appearance="Primary"
                           Icon="{ui:SymbolIcon Checkmark24}" Click="Apply_Click" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
