<ui:FluentWindow x:Class="TaskbarGroups.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:TaskbarGroups.App"
        mc:Ignorable="d"
        Title="Taskbar Groups"
        Height="620" Width="940"
        MinHeight="480" MinWidth="680"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Taskbar Groups" Padding="12,6">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="AppsList24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="28,8,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Loc_Main_Heading}"
                               FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{DynamicResource Loc_Main_Subheading}"
                               FontSize="13" Margin="0,2,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:Button x:Name="AddGroupButton"
                           Content="{DynamicResource Loc_Main_AddGroup}"
                           Icon="{ui:SymbolIcon Add24}"
                           Appearance="Primary"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Click="AddGroupButton_Click" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <Grid>
                    <ItemsControl x:Name="GroupsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,16,16" Width="248" Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="11"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <Grid>
                                                    <ui:SymbolIcon Symbol="AppsList24" FontSize="26"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   Visibility="{Binding Icon, Converter={StaticResource NullToVisibilityConverter}}" />
                                                    <Image Source="{Binding Icon}" Width="40" Height="40"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{Binding ShortcutCountText}" FontSize="12" Margin="0,2,0,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>

                                        <ui:Button Grid.Row="1" Content="{DynamicResource Loc_Main_Pin}"
                                                   Icon="{ui:SymbolIcon Pin24}"
                                                   Appearance="Primary" HorizontalAlignment="Stretch"
                                                   Tag="{Binding}" Click="PinToTaskbar_Click" />

                                        <Grid Grid.Row="2" Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:Button Grid.Column="0" Content="{DynamicResource Loc_Common_Edit}" Icon="{ui:SymbolIcon Edit24}"
                                                       HorizontalAlignment="Stretch" Margin="0,0,4,0"
                                                       Tag="{Binding}" Click="EditGroup_Click" />
                                            <ui:Button Grid.Column="1" Content="{DynamicResource Loc_Common_Delete}" Icon="{ui:SymbolIcon Delete24}"
                                                       HorizontalAlignment="Stretch" Margin="4,0,0,0"
                                                       Tag="{Binding}" Click="DeleteGroup_Click" />
                                        </Grid>
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="0,60,0,0">
                        <ui:SymbolIcon Symbol="AppsAddIn24" FontSize="56"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="{DynamicResource Loc_Main_EmptyTitle}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Margin="0,16,0,0" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{DynamicResource Loc_Main_EmptySubtitle}"
                                   FontSize="13" Margin="0,4,0,16" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:Button Content="{DynamicResource Loc_Main_CreateFirst}"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Appearance="Primary"
                                   HorizontalAlignment="Center"
                                   Click="AddGroupButton_Click" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
